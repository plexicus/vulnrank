{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CurationStatusIndex",
  "type": "object",
  "required": ["WARNING", "generated_at", "schema_version", "entries"],
  "properties": {
    "WARNING": {
      "type": "string",
      "const": "AI-generated content. Accuracy not guaranteed. See https://github.com/plexicus/vulnrank/blob/main/ACCURACY.md"
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "schema_version": { "type": "string" },
    "entries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["ecosystem", "package", "status", "confidence"],
        "properties": {
          "ecosystem":      { "type": "string" },
          "package":        { "type": "string" },
          "status":         { "type": "string", "enum": ["pending", "curating", "curated", "failed"] },
          "confidence":     { "type": "string", "enum": ["high", "medium", "low"] },
          "curated_at":     { "type": ["string", "null"], "format": "date-time" },
          "model":          { "type": ["string", "null"] },
          "prompt_version": { "type": ["string", "null"] },
          "human_reviewed": { "type": "boolean" },
          "error":          { "type": ["string", "null"] },
          "attempted_at":   { "type": ["string", "null"], "format": "date-time" },
          "retry_count":    { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
